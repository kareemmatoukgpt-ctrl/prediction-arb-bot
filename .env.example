# Exchange mode: 'live' uses direct REST APIs, 'mock' uses fake data (no network)
EXCHANGE_MODE=live

# Exchange API base URLs (defaults shown — only override if using a proxy or local stub)
# PM_GAMMA_URL=https://gamma-api.polymarket.com
# PM_CLOB_URL=https://clob.polymarket.com
# KALSHI_API_URL=https://api.elections.kalshi.com/trade-api/v2

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/prediction_arb_bot

# Polymarket (read-only for V1 paper trading)
# POLYMARKET_PRIVATE_KEY=
# POLYMARKET_PROXY_ADDRESS=

# Kalshi (read-only for V1 paper trading)
# KALSHI_API_KEY=
# KALSHI_PRIVATE_KEY=

# Ingestion intervals (milliseconds)
MARKET_REFRESH_INTERVAL_MS=600000
ORDERBOOK_REFRESH_INTERVAL_MS=5000

# Arb engine — cost model (all in basis points, 1 bps = 0.01%)
ARB_THRESHOLD_BPS=50          # minimum edge to flag as arb
SLIPPAGE_BPS=10               # expected execution slippage per side
PM_TAKER_FEE_BPS=0            # Polymarket taker fee (currently 0 on CLOB)
KALSHI_TAKER_FEE_BPS=0        # Kalshi taker fee
DEFAULT_TRADE_SIZE_USD=100

# Paper trading
SIM_LATENCY_MIN_MS=250
SIM_LATENCY_MAX_MS=2000
SIM_SLIPPAGE_BPS=10

# Server
API_PORT=3001
