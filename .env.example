# Exchange mode: 'live' connects to real exchanges via pmxt, 'mock' uses fake data
EXCHANGE_MODE=live

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/prediction_arb_bot

# Polymarket (read-only for V1 paper trading)
# POLYMARKET_PRIVATE_KEY=
# POLYMARKET_PROXY_ADDRESS=

# Kalshi (read-only for V1 paper trading)
# KALSHI_API_KEY=
# KALSHI_PRIVATE_KEY=

# Ingestion intervals (milliseconds)
MARKET_REFRESH_INTERVAL_MS=600000
ORDERBOOK_REFRESH_INTERVAL_MS=5000

# Arb engine
BUFFER_BPS=50
DEFAULT_TRADE_SIZE_USD=100

# Paper trading
SIM_LATENCY_MIN_MS=250
SIM_LATENCY_MAX_MS=2000
SIM_SLIPPAGE_BPS=10

# Server
API_PORT=3001
